{
  "name": "@workspace/api-server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "predev": "node -e \"const fs = require('fs'); if (!fs.existsSync('.env')) fs.copyFileSync('.env.template', '.env');\"",
    "dev": "cross-env NODE_ENV=development pnpm run build && pnpm run start",
    "build": "node ./build.mjs",
    "start": "node --env-file=.env --enable-source-maps ./dist/index.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clear-seed": "tsx --env-file=.env src/clear-seed.ts",
    "seed": "tsx --env-file=.env src/seed.ts",
    "db:push": "cd db && pnpm run push",
    "db:push-force": "cd db && pnpm run push-force",
    "db:studio": "cd db && drizzle-kit studio --config ./drizzle.config.ts"
  },
  "dependencies": {
    "@opentelemetry/semantic-conventions": "^1.41.1",
    "@workspace/api-zod": "workspace:*",
    "@workspace/db": "workspace:*",
    "better-auth": "^1.6.23",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "drizzle-orm": "catalog:",
    "express": "^5.2.1",
    "multer": "^2.1.1",
    "openid-client": "^6.8.4",
    "pino": "^9.14.0",
    "pino-http": "^10.5.0"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/multer": "^2.1.0",
    "@types/node": "catalog:",
    "cross-env": "^7.0.3",
    "esbuild": "0.27.3",
    "esbuild-plugin-pino": "^2.3.3",
    "pino-pretty": "^13.1.3",
    "thread-stream": "3.1.0",
    "tsx": "catalog:",
    "typescript": "catalog:"
  }
}
